{
  "compilerOptions": {
    /* Base */
    "target": "ES2020",
    "module": "Node16",
    "lib": ["ES2020"],

    /* Rutas */
    "rootDir": "./src",
    "outDir": "./dist",

    /* Módulos */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "node16",
    "resolveJsonModule": true,

    /* Calidad de código */
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    /* Desarrollo */
    "sourceMap": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "tests"]
}